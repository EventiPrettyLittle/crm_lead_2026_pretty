// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  role         String        @default("OPERATOR") // ADMIN, OPERATOR
  phone        String?
  leads        Lead[]
  appointments Appointment[]
  googleTokens String?     @map("googleTokens")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  externalId String? @unique // ID from Google Sheet/Excel

  // Import Fields
  leadCreatedAt      DateTime? // Data Lead
  countryCode        String?   // Codice Paese
  eventType          String?   // Tipologia Evento
  guestsCount        String?   // Invitati
  productInterest    String?   // Prodotto
  eventDate          DateTime? // Data Evento
  eventLocation      String?   // Luogo Evento (Indirizzo Completo)
  locationName       String?   // Nome Location (es: Villa Ravaschieri)
  eventCity          String?   // Città estratta
  eventProvince      String?   // Provincia estratta
  eventRegion        String?   // Regione estratta
  firstName          String?   // Nome
  lastName           String?   // Cognome
  phoneRaw           String?   // Telefono
  phoneNormalized    String?   // Telefono normalizzato
  email              String?   // Email
  preferredContactTime String? // Quando Vorresti Essere Contattato
  additionalServices   String? // Servizi Aggiuntivi (CSV)

  // Operator Fields
  stage           String    @default("NUOVO") // NUOVO, CONTATTATO, QUALIFICATO, PREVENTIVO, FOLLOWUP, APPUNTAMENTO, VINTO, PERSO
  ownerId         String?
  owner           User?     @relation(fields: [ownerId], references: [id])
  contactedAt     DateTime?
  interestLevel   String?   // BASSO, MEDIO, ALTO
  budgetRange     String?
  priceTarget     Decimal?
  notesInternal   String?
  nextFollowupAt  DateTime?
  lastStatus      String?   // CONTATTATO, NON_RISPONDE, DA_RICONTATTARE
  lastStatusAt    DateTime?
  lostReason      String?   // Nessuna risposta, Prezzo alto, Perso vs competitor, ecc.
  referents       String?   // JSON stringified: [{role, name}]
  quoteSentAt     DateTime?
  createdBy       String?   // Referente che ha creato o gestisce

  // Relations
  activities   Activity[]
  quotes       Quote[]
  appointments Appointment[]
  payments     Payment[]
  deal         Deal?


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id             String    @id @default(cuid())
  leadId         String
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type           String    // CALL, EMAIL, NOTE, SYSTEM, WHATSAPP, RICHIAMO
  notes          String?
  nextFollowupAt DateTime?
  createdAt      DateTime  @default(now())
  // updatedBy    String? // Could link to User
}

model Quote {
  id            String      @id @default(cuid())
  number        Int         // Manual increment in app logic
  leadId        String
  lead          Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status        String      @default("BOZZA") // BOZZA, INVIATO, ACCETTATO, RIFIUTATO
  paymentMethod String?     // CARTA, CONTANTI, BONIFICO, RATEALE
  totalAmount   Decimal     @default(0) // Net total (after discounts)
  discountTotal Decimal     @default(0) // Global discount on total
  notes         String?
  items         QuoteItem[]
  payments      Payment[]
  sentAt        DateTime?
  createdBy     String?
  creatorPhone  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Payment {
  id        String   @id @default(cuid())
  quoteId   String?  // Opzionale ora
  quote     Quote?   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  amount    Decimal
  method    String?  // BONIFICO, CONTANTI, CARTA, POS, ECC.
  notes     String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model QuoteItem {
  id            String   @id @default(cuid())
  quoteId       String
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description   String
  quantity      Int      @default(1)
  originalPrice Decimal? // Prezzo di listino
  unitPrice     Decimal  // Prezzo scontato finale
  discount      Decimal? @default(0) // Sconto applicato (valore assoluto o %)
  vatRate       Decimal  @default(22)
  totalPrice    Decimal  // Calculated: (quantity * unitPrice)
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?
  price       Decimal
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Appointment {
  id            String   @id @default(cuid())
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id])
  title         String?
  startTime     DateTime // Data + Ora
  duration      Int      @default(60) // Minutes
  location      String?
  notes         String?
  googleEventId String?  // ID for Google Calendar sync
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanySettings {
  id           String   @id @default("settings_main")
  companyName  String?
  address      String?
  vatNumber    String?
  iban         String?
  phone        String?
  email        String?
  referente    String?
  updatedAt    DateTime @updatedAt
}

model SystemSettings {
  id        String   @id @default("global")
  logoUrl   String?
  logoWidth Int      @default(150)
  updatedAt DateTime @updatedAt
}

model Deal {
  id                String   @id @default(cuid())
  leadId            String   @unique
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  // Event Details
  numGuests         String?
  numFavors         String?
  arrivalTime       String?
  endTime           String?
  deliveryType      String?  // CONSEGNA, CONSEGNA IN LOCATION, LIVE SHOW
  
  // Favor 1
  favor1_title      String?
  favor1_colors     String?
  favor1_graphics   String?
  favor1_stick      String?
  favor1_scents     String?
  favor1_notes      String?
  
  // Pack 1
  pack1_ribbon     String?
  pack1_confetti   String?
  pack1_graphics   String?
  
  // Accessories 1
  acc1_product     String?
  acc1_colors      String?
  acc1_graphics    String?

  // Accessories 2
  acc2_product     String?
  acc2_colors      String?
  acc2_graphics    String?
  
  // Favor 2
  favor2_title      String?
  favor2_colors     String?
  favor2_graphics   String?
  favor2_stick      String?
  favor2_scents     String?
  favor2_notes      String?
  
  // Pack 2
  pack2_ribbon     String?
  pack2_confetti   String?
  pack2_graphics   String?

  // Favor 3
  favor3_title      String?
  favor3_colors     String?
  favor3_graphics   String?
  favor3_stick      String?
  favor3_scents     String?
  favor3_notes      String?
  
  // Pack 3
  pack3_ribbon     String?
  pack3_confetti   String?
  pack3_graphics   String?
  
  // Favor 4
  favor4_title      String?
  favor4_colors     String?
  favor4_graphics   String?
  favor4_stick      String?
  favor4_scents     String?
  favor4_notes      String?

  // Pack 4
  pack4_ribbon     String?
  pack4_confetti   String?
  pack4_graphics   String?

  // Accessories 3
  acc3_product     String?
  acc3_colors      String?
  acc3_graphics    String?

  // Extra 1
  extra1_title     String?
  extra1_notes     String?
  
  // Extra 2
  extra2_title     String?
  extra2_notes     String?

  // Extra 3
  extra3_title     String?
  extra3_notes     String?

  // Extra 4
  extra4_title     String?
  extra4_notes     String?

  // Assignment Mapping (JSON)
  productAssignments String? // [{"quoteItemId": "...", "target": "favor1", "quantity": 10}]
  
  // General
  notes             String?
  status            String   @default("IN_LAVORAZIONE") // IN_LAVORAZIONE, PRONTO, CONSEGNATO
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
